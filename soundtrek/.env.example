# ── Prisma (migrations + seeding) ────────────────────────────────────────────
# Must be the direct connection (port 5432), NOT the transaction pooler.
# Supabase: Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ── Supabase JS client (browser runtime) ─────────────────────────────────────
# Supabase: Project Settings → API
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service role (server-side scripts only — never expose to browser) ─
# Supabase: Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Ingestion scripts ─────────────────────────────────────────────────────────

# IGDB (game metadata + cover art)
# Get credentials at: dev.twitch.tv → register an app → copy Client ID + Secret
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# YouTube Data API v3 (ingestion scripts only — never exposed to browser)
# Get a key at: console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key
# Optional: override default batch size (default 80, YouTube quota = ~100/day free)
# INGEST_BATCH_SIZE=80

# YouTube proxy Worker (Cloudflare Worker — keeps API key off the client)
# Local dev: http://localhost:8787 (run `npm run dev` in workers/youtube-proxy)
# Production: your deployed workers.dev URL
VITE_YOUTUBE_PROXY_URL=https://soundtrek-youtube-proxy.[your-account].workers.dev

SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...


# ── Dev ───────────────────────────────────────────────────────────────────────
VITE_USE_MOCK_DATA=false
