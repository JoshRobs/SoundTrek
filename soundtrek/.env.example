# ── Prisma (server-side: migrations + seeding) ───────────────────────────────
# Transaction pooler — port 6543, used by Prisma Client
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection — port 5432, used by prisma migrate
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Supabase JS client (browser runtime queries) ─────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Set to "true" to skip Supabase and render mock data locally
VITE_USE_MOCK_DATA=false
