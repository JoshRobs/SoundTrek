generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Composer {
  slug        String   @id
  name        String
  support_url String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@map("composers")
}

model ContactMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String?
  email      String
  message    String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("contact_messages")
}

model Submission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_title   String
  notes        String?
  status       String   @default("pending")
  submitted_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("submissions")
}

model Soundtrack {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_title          String
  composer            String
  console             String
  release_year        Int
  cover_image_url     String?
  youtube_playlist_id String?
  youtube_video_id    String?
  source_type         String
  spotify_id          String?
  spotify_type        String?
  streaming_links     Json     @default("[]")
  mood_tags           String[]
  genre_tags          String[]
  theme_tags          String[]
  likes               Int      @default(0)
  created_at          DateTime @default(now()) @db.Timestamptz(6)

  @@map("soundtracks")
}
